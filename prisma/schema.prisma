// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================
// Enums
// ==================

enum UserRole {
  SERVICE_USER
  SERVICE_PROVIDER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum ServiceStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeResolution {
  REFUND_FULL
  REFUND_PARTIAL
  NO_REFUND
  REDO_SERVICE
  MUTUAL_AGREEMENT
  DISMISSED
}

// ==================
// Wallet & Withdrawal Enums
// ==================

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletTransactionSource {
  REFUND              // User receives refund
  BOOKING_PAYMENT     // User pays with wallet
  SERVICE_EARNING     // Provider earns from service
  WITHDRAWAL          // Provider withdraws to bank
  WITHDRAWAL_REVERSAL // Failed withdrawal returned
  ADMIN_ADJUSTMENT    // Manual admin adjustment
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PayoutFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  MANUAL              // No auto-payout, manual withdrawal only
}

enum AdminAction {
  BAN_USER
  UNBAN_USER
  RESTRICT_USER
  UNRESTRICT_USER
  SUSPEND_USER
  ACTIVATE_USER
  PROCESS_WITHDRAWAL
  REJECT_WITHDRAWAL
  PROCESS_REFUND
  RESOLVE_DISPUTE
  ADJUST_WALLET
  UPDATE_USER_ROLE
  DELETE_USER
  VERIFY_PROVIDER
  REJECT_PROVIDER
  APPROVE_SERVICE
  REJECT_SERVICE
  SUSPEND_SERVICE
}

// ==================
// Models
// ==================

model User {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  email     String        @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  profilePhoto String?    // Cloudinary URL for profile photo
  role      UserRole      @default(SERVICE_USER)
  activeRole UserRole?    // Current active mode (null = same as role, allows toggling for providers)
  status    AccountStatus @default(PENDING)

  // Email verification
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?   // Hashed OTP
  emailVerifyExpiry DateTime? // OTP expiry time
  pendingEmail      String?   // Staged new email awaiting OTP confirmation
  
  // Push Notifications (OneSignal)
  oneSignalPlayerId String?   // OneSignal Player ID for push notifications
  pushEnabled       Boolean   @default(true) // User preference for push notifications
  
  // Security fields
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  
  // Password reset
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  
  // Ban system
  bannedAt            DateTime?
  bannedUntil         DateTime?       // null = permanent ban
  banReason           String?
  bannedBy            String?         @db.ObjectId
  
  // Restriction system (can login but can't transact)
  restrictedAt        DateTime?
  restrictedUntil     DateTime?       // null = permanent restriction
  restrictionReason   String?
  restrictedBy        String?         @db.ObjectId
  
  // Session invalidation (tokens issued before this time are invalid)
  tokenInvalidatedAt  DateTime?
  
  // Provider specific fields (only for SERVICE_PROVIDER role)
  provider  ServiceProvider?
  
  // Wallet relation
  wallet    Wallet?
  
  // Relations
  bookingsAsUser Booking[] @relation("UserBookings")
  reviews        Review[]  @relation("UserReviews")
  favourites     Favourite[] @relation("UserFavourites")
  providerLikes  ProviderLike[] @relation("UserProviderLikes")
  settings       UserSettings?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ServiceProvider {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  userId              String             @unique @db.ObjectId
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessName        String
  businessDescription String?
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  
  // Location
  address             String
  city                String
  state               String
  country             String
  latitude            Float?
  longitude           Float?
  
  // Documents for verification
  documents           String[]
  
  // Portfolio/Gallery images
  images              String[]
  
  // Relations
  services            Service[]
  bookings            Booking[] @relation("ProviderBookings")
  reviews             Review[]  @relation("ProviderReviews")
  likes               ProviderLike[] @relation("ProviderLikes")
  bankAccounts        ProviderBankAccount[]
  payoutSchedule      PayoutSchedule?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("service_providers")
}

model ServiceCategory {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  isActive    Boolean   @default(true)
  
  services    Service[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("service_categories")
}

model Service {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  providerId  String          @db.ObjectId
  provider    ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId  String          @db.ObjectId
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  
  name        String
  slug        String
  description String
  price       Float
  duration    Int             // Duration in minutes
  status      ServiceStatus   @default(DRAFT)
  
  images      String[]
  
  bookings    Booking[]
  favourites  Favourite[] @relation("ServiceFavourites")
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Indexes for common queries
  @@unique([providerId, slug])
  @@index([status])
  @@index([categoryId, status])
  @@index([providerId, status])
  @@map("services")
}

model Booking {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  userId        String          @db.ObjectId
  user          User            @relation("UserBookings", fields: [userId], references: [id])
  providerId    String          @db.ObjectId
  provider      ServiceProvider @relation("ProviderBookings", fields: [providerId], references: [id])
  serviceId     String          @db.ObjectId
  service       Service         @relation(fields: [serviceId], references: [id])
  
  status        BookingStatus   @default(PENDING)
  scheduledDate DateTime
  scheduledTime String
  
  // Address for service
  address       String
  city          String
  state         String
  notes         String?
  
  // Pricing
  servicePrice  Float
  commission    Float
  totalAmount   Float
  
  // Payment
  payment       Payment?
  
  // Review
  review        Review?
  
  // Dispute
  dispute       Dispute?
  
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancellationReason String?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Indexes for common queries
  @@index([userId, status])
  @@index([providerId, status])
  @@index([status, scheduledDate])
  @@index([scheduledDate])
  @@map("bookings")
}

model Payment {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  bookingId       String        @unique @db.ObjectId
  booking         Booking       @relation(fields: [bookingId], references: [id])
  
  amount          Float
  commission      Float
  providerPayout  Float
  paystackFee     Float?        // Paystack processing fee
  
  status          PaymentStatus @default(PENDING)
  paymentMethod   String?
  transactionRef  String?       @unique
  
  paidAt          DateTime?
  refundedAt      DateTime?
  payoutAt        DateTime?     // When provider was paid out
  
  // Withdrawal eligibility (dispute window - typically 24-48 hours after completion)
  withdrawableAt  DateTime?     // When provider can withdraw this earning
  
  // Refund details
  refundAmount    Float?
  refundReason    String?
  refundedBy      String?       @db.ObjectId  // Admin who processed refund
  refundedVia     String?       // DISPUTE, CANCELLATION, MANUAL, CHARGEBACK
  
  // Link to wallet transaction when paid to provider wallet
  walletTransactionId String?   @db.ObjectId
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([withdrawableAt])
  @@map("payments")
}

model Review {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  bookingId   String          @unique @db.ObjectId
  booking     Booking         @relation(fields: [bookingId], references: [id])
  userId      String          @db.ObjectId
  user        User            @relation("UserReviews", fields: [userId], references: [id])
  providerId  String          @db.ObjectId
  provider    ServiceProvider @relation("ProviderReviews", fields: [providerId], references: [id])
  
  rating      Int             // 1-5
  comment     String?
  
  // Provider response
  response    String?
  respondedAt DateTime?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("reviews")
}

model Favourite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation("UserFavourites", fields: [userId], references: [id], onDelete: Cascade)
  serviceId String   @db.ObjectId
  service   Service  @relation("ServiceFavourites", fields: [serviceId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  // Ensure a user can only favourite a service once
  @@unique([userId, serviceId])
  @@map("favourites")
}

model ProviderLike {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  userId     String          @db.ObjectId
  user       User            @relation("UserProviderLikes", fields: [userId], references: [id], onDelete: Cascade)
  providerId String          @db.ObjectId
  provider   ServiceProvider @relation("ProviderLikes", fields: [providerId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime        @default(now())

  // Ensure a user can only like a provider once
  @@unique([userId, providerId])
  @@map("provider_likes")
}

model Dispute {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  bookingId     String           @unique @db.ObjectId
  booking       Booking          @relation(fields: [bookingId], references: [id])
  
  // Who raised the dispute
  raisedById    String           @db.ObjectId
  raisedByRole  UserRole         // SERVICE_USER or SERVICE_PROVIDER
  
  // Dispute details
  reason        String
  description   String
  evidence      String[]         // URLs to uploaded evidence (images, documents)
  
  status        DisputeStatus    @default(OPEN)
  
  // Resolution (filled when resolved)
  resolution      DisputeResolution?
  resolutionNotes String?
  resolvedById    String?          @db.ObjectId
  resolvedAt      DateTime?
  
  // Refund amount if applicable
  refundAmount    Float?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("disputes")
}

// ==================
// Messaging & Notifications
// ==================

enum ConversationType {
  USER_PROVIDER       // User chatting with Service Provider (about bookings)
  USER_ADMIN          // User/Provider support chat with Admin
  ADMIN_SUPERADMIN    // Admin chatting with Super Admin
  BOOKING_RELATED     // Chat tied to a specific booking
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationType {
  // Booking notifications
  BOOKING_CREATED
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_STARTED
  BOOKING_COMPLETED
  
  // Payment notifications
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REFUND_PROCESSED
  
  // Review notifications
  REVIEW_RECEIVED
  REVIEW_RESPONSE
  
  // Provider notifications
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  SERVICE_APPROVED
  SERVICE_REJECTED
  SERVICE_SUSPENDED
  
  // Dispute notifications
  DISPUTE_OPENED
  DISPUTE_UPDATED
  DISPUTE_RESOLVED
  
  // Message notifications
  NEW_MESSAGE
  
  // System notifications
  ACCOUNT_SUSPENDED
  ACCOUNT_ACTIVATED
  SYSTEM_ANNOUNCEMENT
}

model Conversation {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  type            ConversationType
  
  // Participants (store user IDs)
  participantIds  String[]         @db.ObjectId
  
  // Optional: Link to booking for booking-related chats
  bookingId       String?          @db.ObjectId
  
  // For support chats - subject/topic
  subject         String?
  
  // Track if conversation is active or archived
  isActive        Boolean          @default(true)
  
  // Last message info for quick display
  lastMessageAt   DateTime?
  lastMessageText String?
  
  // Messages in this conversation
  messages        Message[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("conversations")
}

model Message {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String        @db.ObjectId
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  // Sender info
  senderId        String        @db.ObjectId
  senderRole      UserRole      // To identify if sender is user, provider, admin, etc.
  
  // Message content
  content         String
  
  // Attachments (images, files)
  attachments     String[]
  
  // Message status
  status          MessageStatus @default(SENT)
  
  // Read receipts - store IDs of users who have read
  readBy          String[]      @db.ObjectId
  readAt          DateTime?
  
  // For replies/threading
  replyToId       String?       @db.ObjectId
  
  // Soft delete
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("messages")
}

model Notification {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  
  // Recipient
  userId      String           @db.ObjectId
  
  // Notification details
  type        NotificationType
  title       String
  message     String
  
  // Related entity (booking, review, dispute, etc.)
  entityType  String?          // "booking", "review", "dispute", "message", etc.
  entityId    String?          @db.ObjectId
  
  // Additional data as JSON string
  metadata    String?
  
  // Status
  isRead      Boolean          @default(false)
  readAt      DateTime?
  
  // For push notifications
  isPushed    Boolean          @default(false)
  pushedAt    DateTime?
  
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ==================
// User Settings
// ==================

model UserSettings {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @unique @db.ObjectId
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Push / in-app notification preferences (per category)
  notifyBookingUpdates    Boolean @default(true)   // Booking accepted/rejected/completed
  notifyMessages          Boolean @default(true)   // New chat messages
  notifyReviews           Boolean @default(true)   // New review on your service / response to your review
  notifyPromotions        Boolean @default(false)  // Marketing & promotional emails
  notifyDisputeUpdates    Boolean @default(true)   // Dispute status changes
  notifyProviderVerification Boolean @default(true) // Verification approved/rejected

  // Email notification preferences
  emailBookingUpdates     Boolean @default(true)
  emailMessages           Boolean @default(false)  // Digest only by default
  emailReviews            Boolean @default(true)
  emailPromotions         Boolean @default(false)
  emailNewsletters        Boolean @default(false)

  // Locale & display
  language                String  @default("en")   // ISO 639-1 e.g. "en", "fr"
  timezone                String  @default("Africa/Lagos") // IANA timezone
  currency                String  @default("NGN")  // ISO 4217

  // Privacy
  showProfileToPublic     Boolean @default(true)
  showPhoneToProviders    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// ==================
// Wallet System
// ==================

model Wallet {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // All amounts stored in KOBO (integers) to avoid float precision issues
  balance         Int      @default(0)  // Available balance (in kobo)
  pendingBalance  Int      @default(0)  // Pending earnings not yet withdrawable (in kobo)
  
  currency        String   @default("NGN")
  isLocked        Boolean  @default(false)  // Lock during pending withdrawal
  lockedReason    String?
  
  transactions    WalletTransaction[]
  withdrawals     Withdrawal[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("wallets")
}

model WalletTransaction {
  id              String                    @id @default(auto()) @map("_id") @db.ObjectId
  walletId        String                    @db.ObjectId
  wallet          Wallet                    @relation(fields: [walletId], references: [id])
  
  type            WalletTransactionType     // CREDIT or DEBIT
  source          WalletTransactionSource
  
  amount          Int                       // In kobo
  balanceBefore   Int                       // In kobo
  balanceAfter    Int                       // In kobo
  
  description     String
  reference       String                    @unique  // Idempotency key
  
  // Link to source entity
  bookingId       String?                   @db.ObjectId
  paymentId       String?                   @db.ObjectId
  withdrawalId    String?                   @db.ObjectId
  
  // For admin adjustments
  adjustedBy      String?                   @db.ObjectId
  adjustmentReason String?
  
  createdAt       DateTime                  @default(now())
  
  @@index([walletId, createdAt])
  @@index([source])
  @@map("wallet_transactions")
}

model Withdrawal {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  walletId          String           @db.ObjectId
  wallet            Wallet           @relation(fields: [walletId], references: [id])
  providerId        String           @db.ObjectId
  
  amount            Int              // In kobo
  fee               Int              @default(0)  // Transfer fee in kobo
  netAmount         Int              // amount - fee (what provider receives)
  
  status            WithdrawalStatus @default(PENDING)
  
  // Snapshot bank details at request time (prevents mid-withdrawal changes)
  bankCode          String
  bankName          String
  accountNumber     String
  accountName       String
  
  // Paystack transfer details
  transferCode      String?
  transferReference String?          @unique
  
  // Processing details
  requestedAt       DateTime         @default(now())
  processedAt       DateTime?
  completedAt       DateTime?
  
  // Failure handling
  failureReason     String?
  retryCount        Int              @default(0)
  lastRetryAt       DateTime?
  
  // Admin processing
  processedBy       String?          @db.ObjectId
  
  // Link to scheduled payout if applicable
  scheduledPayoutId String?          @db.ObjectId
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([walletId, status])
  @@index([providerId, status])
  @@index([status, createdAt])
  @@map("withdrawals")
}

// ==================
// Provider Bank Account
// ==================

model ProviderBankAccount {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  providerId      String          @db.ObjectId
  provider        ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  bankCode        String
  bankName        String
  accountNumber   String
  accountName     String          // Resolved from Paystack
  
  isDefault       Boolean         @default(false)
  isVerified      Boolean         @default(false)
  
  // Paystack recipient code for transfers
  recipientCode   String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@unique([providerId, accountNumber, bankCode])
  @@index([providerId])
  @@map("provider_bank_accounts")
}

// ==================
// Scheduled Payouts
// ==================

model PayoutSchedule {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  providerId      String          @unique @db.ObjectId
  provider        ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  frequency       PayoutFrequency @default(MANUAL)
  
  // For WEEKLY: 0=Sunday, 1=Monday, etc.
  dayOfWeek       Int?
  
  // For MONTHLY: 1-28 (avoid 29-31 edge cases)
  dayOfMonth      Int?
  
  // Minimum amount to trigger payout (in kobo) - default ₦5,000
  minimumAmount   Int             @default(500000)
  
  // Timezone for scheduling
  timezone        String          @default("Africa/Lagos")
  
  isActive        Boolean         @default(true)
  
  // Preferred bank account for payouts
  bankAccountId   String?         @db.ObjectId
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@map("payout_schedules")
}

model ScheduledPayout {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  providerId      String           @db.ObjectId
  
  amount          Int              // Total amount in kobo
  paymentIds      String[]         @db.ObjectId  // Payments included in this payout
  
  scheduledFor    DateTime
  status          WithdrawalStatus @default(PENDING)
  
  // Link to actual withdrawal when processed
  withdrawalId    String?          @db.ObjectId
  
  processedAt     DateTime?
  failureReason   String?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([providerId, status])
  @@index([scheduledFor, status])
  @@map("scheduled_payouts")
}

// ==================
// Admin Audit Log
// ==================

model AdminAuditLog {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  
  action          AdminAction
  targetType      String      // "User", "Provider", "Withdrawal", "Payment", etc.
  targetId        String      @db.ObjectId
  
  performedBy     String      @db.ObjectId  // Admin user ID
  performedByRole String      // ADMIN or SUPER_ADMIN
  
  previousValue   String?     // JSON of previous state
  newValue        String?     // JSON of new state
  
  reason          String?     // Why action was taken
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime    @default(now())
  
  @@index([performedBy, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}
